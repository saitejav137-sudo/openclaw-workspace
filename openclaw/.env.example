# OpenClaw Environment Configuration

# API Key for authentication (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
OPENCLAW_API_KEY=

# Database
POSTGRES_PASSWORD=openclaw123

# Telegram (get from @BotFather)
OPENCLAW_TELEGRAM_ENABLED=false
OPENCLAW_TELEGRAM_TOKEN=
OPENCLAW_TELEGRAM_CHAT_ID=

# Webhook
OPENCLAW_WEBHOOK_URL=

# Grafana
GRAFANA_PASSWORD=admin123

# X11 Display (for screen capture in Docker)
DISPLAY=:0
