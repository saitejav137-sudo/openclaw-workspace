{
   "action": {
      "default_icon": {
         "128": "icons/icon128.png",
         "16": "icons/icon16.png",
         "32": "icons/icon32.png",
         "48": "icons/icon48.png"
      },
      "default_title": "Clawdbot Browser Relay (click to attach/detach)"
   },
   "background": {
      "service_worker": "background.js",
      "type": "module"
   },
   "description": "Attach OpenClaw (MoltBot & ClawdBot) to your existing Chrome tab via a local CDP relay server.",
   "host_permissions": [ "http://127.0.0.1/*", "http://localhost/*" ],
   "icons": {
      "128": "icons/icon128.png",
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "OpenClaw Browser Relay",
   "options_ui": {
      "open_in_tab": true,
      "page": "options.html"
   },
   "permissions": [ "debugger", "tabs", "activeTab", "storage" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "0.1.0"
}
