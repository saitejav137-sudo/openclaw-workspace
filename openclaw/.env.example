# OpenClaw Environment Configuration

# API Key for authentication (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
OPENCLAW_API_KEY=

# Database (generate secure password: python -c "import secrets; print(secrets.token_urlsafe(16))")
POSTGRES_PASSWORD=

# Telegram (get from @BotFather)
OPENCLAW_TELEGRAM_ENABLED=false
OPENCLAW_TELEGRAM_TOKEN=
OPENCLAW_TELEGRAM_CHAT_ID=

# Webhook
OPENCLAW_WEBHOOK_URL=

# Grafana (generate secure password: python -c "import secrets; print(secrets.token_urlsafe(16))")
GRAFANA_PASSWORD=

# X11 Display (for screen capture in Docker)
DISPLAY=:0

# TLS/HTTPS (set to true to enable HTTPS)
OPENCLAW_TLS_ENABLED=false
OPENCLAW_TLS_CERT_PATH=
OPENCLAW_TLS_KEY_PATH=
